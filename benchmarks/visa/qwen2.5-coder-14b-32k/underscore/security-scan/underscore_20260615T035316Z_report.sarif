          "message": {
            "text": "Incorrectly handles circular references in objects  [CVSS 10.0: CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:C/C:N/I:H/A:H]"
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "modules/isEmpty.js"
                },
                "region": {
                  "startLine": 7
                }
