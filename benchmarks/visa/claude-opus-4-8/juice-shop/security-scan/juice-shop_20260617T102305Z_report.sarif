          "properties": {
            "severity": "medium",
            "security-severity": "6.5",
            "cvssRating": "Medium",
            "category": "CWE-620",
            "cvssVector": "CVSS:3.1/AV:N/AC:L/PR:L/UI:N/S:U/C:N/I:H/A:N",
            "cwe": "CWE-620",
            "cweId": "CWE-620",
            "cvssScore": 6.5,
            "offensivePriority": "P3",
