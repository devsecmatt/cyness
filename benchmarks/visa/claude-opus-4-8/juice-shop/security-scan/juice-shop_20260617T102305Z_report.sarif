          "properties": {
            "severity": "critical",
            "security-severity": "10.0",
            "cvssRating": "Critical",
            "category": "CWE-347: Improper Verification of Cryptographic Signature",
            "cvssVector": "CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:C/C:H/I:H/A:N",
            "cwe": "CWE-347 - Improper Verification of Cryptographic Signature",
            "cweId": "CWE-347",
            "cweName": "Improper Verification of Cryptographic Signature",
            "cvssScore": 10.0,
            "offensivePriority": "P3",
