          "level": "warning",
          "message": {
            "text": "GET /api/Feedbacks lists all feedback without authentication  [CVSS 5.3: CVSS:3.1/AV:N/AC:L/PR:N/UI:N/S:U/C:L/I:N/A:N]"
          },
          "locations": [
            {
              "physicalLocation": {
